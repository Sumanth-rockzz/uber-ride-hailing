{
  "info": {
    "_postman_id": "8ab71e9c-7307-42d7-9174-2e65f6c84de7",
    "name": "Uber Clone API",
    "description": "Local Postman collection for the current Uber Clone backend. `POST /api/rides` requires a JWT from auth-service; most other endpoints are currently open.",
